# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ──
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (email) ──
RESEND_API_KEY=re_...

# ── Sentry (error tracking) ──
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_AUTH_TOKEN=sntryu_...
SENTRY_ORG=readee
SENTRY_PROJECT=readee

# ── PostHog (analytics) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Google Cloud (content generation — not needed for app runtime) ──
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_API_KEY=...
GEMINI_API_KEY=...

# ── Google Classroom OAuth (teacher-facing roster import) ──
# These are for the Readee OAuth Web Client in GCP project "readee-487403".
# Client ID is public (browsers see it during OAuth). Client secret is NOT —
# never commit it; set it only in Vercel / .env.local.
# Authorized redirect URI in Cloud Console must include:
#   https://learn.readee.app/api/classroom/google/callback
GOOGLE_OAUTH_CLIENT_ID=1075670453139-druaffg31sgr95fohjs2j0q1pk5vuovg.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=set-in-vercel-and-.env.local-only

# ── Student session cookie signing (classroom-owned student sign-in) ──
# Falls back to SUPABASE_JWT_SECRET if unset. Set a dedicated value for
# prod to rotate independently.
STUDENT_SESSION_SECRET=long-random-string-here

# ── App base URL (used in OAuth redirect + invite email links) ──
NEXT_PUBLIC_APP_URL=https://learn.readee.app

# ── Readee.ai (teacher-facing AI assistant) ──
# Gemini 2.5 Flash via the Google GenAI SDK — same account/billing as
# the TTS + image pipelines. Used by the AI quiz generator in
# /classroom/authoring. Hourly cap is enforced per teacher in
# ai_usage_log; credit economy will layer on later.
# (GEMINI_API_KEY is already declared above.)
